rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // A user can fully manage their own profile document.
      allow read, write: if request.auth.uid == userId;

      // An admin can read their helpers' profiles (for get and list/query).
      allow read: if resource.data.adminId == request.auth.uid;

      // An admin can update a helper's profile (e.g. to remove them).
      // We use get() to check the document's state before the update.
      allow update: if get(/databases/$(database)/documents/users/$(userId)).data.adminId == request.auth.uid;
    }

    match /users/{ownerId}/{collection}/{docId} {
        allow read, write: if request.auth.uid == ownerId ||
                             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminId == ownerId;
    }

    match /invitations/{invitationId} {
      // Anyone can read an invitation to validate it before signing up.
      allow read: if true;

      // Only an authenticated user (an admin) can create an invitation.
      // The adminId in the new invitation must match the creator's UID.
      allow create: if request.auth != null && request.resource.data.adminId == request.auth.uid;

      // An admin can delete their own un-claimed invitations.
      allow delete: if request.auth.uid == resource.data.adminId && resource.data.claimed == false;
      
      // Any authenticated user can claim an unclaimed invitation for themselves.
      allow update: if request.auth != null &&
                     resource.data.claimed == false &&
                     request.resource.data.claimed == true &&
                     request.resource.data.claimedBy == request.auth.uid;
    }
  }
}
